# ==============================================================================
# RM Copilot — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# ==============================================================================

# Application
APP_ENV=development
SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# PostgreSQL + TimescaleDB + pgvector
DATABASE_URL=postgresql+asyncpg://rmcopilot:password@localhost:5432/rmcopilot
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=14400

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_RETRIES=3

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# PII Masking
PII_MASK_ENABLED=true

# Notification Providers
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ML Model Paths
CONVERSION_MODEL_PATH=services/ml/models/conversion_score/model.ubj
CHURN_MODEL_PATH=services/ml/models/churn_score/model.ubj

# RAG
VECTOR_SIMILARITY_THRESHOLD=0.75
RAG_TOP_K=5
