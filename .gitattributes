# Normalize line endings to LF on commit (cross-platform consistency)
* text=auto eol=lf

# Python files
*.py text eol=lf

# Config files
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env.example text eol=lf
*.j2 text eol=lf
*.mako text eol=lf
*.sql text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.ico binary
*.pkl binary
*.ubj binary
*.h5 binary
