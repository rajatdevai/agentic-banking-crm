# =============================================================================
# RM Copilot — .gitignore
# =============================================================================

# --- Secrets / Environment ---
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
*.whl

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.virtualenv/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc
.tox/

# --- Type checking ---
.mypy_cache/
.dmypy.json

# --- Linting ---
.ruff_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- ML model artifacts (large binaries — store in S3/MLflow, not git) ---
*.ubj
*.pkl
*.pickle
*.joblib
*.h5
*.pt
*.pth
services/ml/models/**/*.ubj
services/ml/models/**/*.pkl

# --- Logs ---
*.log
logs/

# --- Docker ---
.docker/

# --- Node (if any frontend tooling) ---
node_modules/
.npm/

# --- Alembic versions cache ---
# Keep migration files but ignore pycache inside
alembic/versions/__pycache__/

# --- pgvector / database dumps ---
*.sql.gz
*.dump

# --- Temp / scratch ---
tmp/
temp/
scratch/
